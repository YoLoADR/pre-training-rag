# ── LLM Provider ──────────────────────────────────────────────────────────────
# "anthropic" → Claude API (dev local)
# "ollama"    → modèle local/VPS via Ollama (production)
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=homebutler

# ── Observabilité ──────────────────────────────────────────────────────────────
# LangSmith (curriculum RAFT) — mettre LANGCHAIN_TRACING_V2=true pour activer
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=homebutler-ai

# Langfuse (alternative self-hostable — pattern pbn/amplifiire)
# TRACING_PROVIDER=langfuse  # décommenter pour utiliser Langfuse à la place
TRACING_PROVIDER=langsmith
LANGFUSE_HOST=http://localhost:3300
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Bases vectorielles ────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db
FAISS_PATH=./data/faiss_index

# ── Services ──────────────────────────────────────────────────────────────────
OPEN_METEO_CACHE_TTL=3600

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Clé API simple pour protéger les endpoints (optionnel en dev)
API_KEY=homebutler-dev-key

# ── UI ────────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
