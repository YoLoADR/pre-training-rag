# ── LLM Provider ──────────────────────────────────────────────────────────────
# "anthropic" → Claude API (dev local)
# "ollama"    → modèle local/VPS via Ollama (production)
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=homebutler

# ── Observabilité ──────────────────────────────────────────────────────────────
# LangSmith (curriculum RAFT) — mettre LANGCHAIN_TRACING_V2=true pour activer
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=homebutler-ai

# Langfuse — cloud.langfuse.com (ou self-hosted)
# TRACING_PROVIDER=langsmith  # pour utiliser LangSmith à la place
TRACING_PROVIDER=langfuse
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── Bases vectorielles ────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma_db
FAISS_PATH=./data/faiss_index

# ── Services ──────────────────────────────────────────────────────────────────
OPEN_METEO_CACHE_TTL=3600

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Clé API simple pour protéger les endpoints (optionnel en dev)
API_KEY=homebutler-dev-key

# ── UI ────────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000

# ── Scope ateliers ────────────────────────────────────────────────────────────
# false = At.05 (routes /rag/evaluate, /chat/compare, /rag/compare-strategies désactivées)
# true  = At.06 uniquement (activer pour la démo comparative finale)
ENABLE_COMPARE_ROUTES=false

# ── ChromaDB (At.03+) ─────────────────────────────────────────────────────────
# Désactiver la télémétrie ChromaDB pour éviter les warnings en session
ANONYMIZED_TELEMETRY=false
