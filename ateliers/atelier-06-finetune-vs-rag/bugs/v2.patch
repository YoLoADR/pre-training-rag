+# BUG v2 — BLEU score utilisé pour mesurer la qualité du ton/style
+def evaluate_style_quality(responses: list[str], references: list[str]) -> float:
+    """
+    BUG : BLEU est une métrique de traduction automatique basée sur le chevauchement
+    de n-grammes. Elle mesure la similarité lexicale, pas la qualité conversationnelle
+    ni le ton 'Merenza'. Un response de haute qualité avec un vocabulaire différent
+    de la référence aura un BLEU très bas malgré une excellente qualité.
+    """
+    from nltk.translate.bleu_score import sentence_bleu, SmoothingFunction
+    scores = []
+    for resp, ref in zip(responses, references):
+        score = sentence_bleu([ref.split()], resp.split(),
+                               smoothing_function=SmoothingFunction().method1)
+        scores.append(score)
+    return sum(scores) / len(scores) if scores else 0.0
+
